# ── Sunucu ──────────────────────────────────────────────
PORT=3001

# ── Frontend URL (CORS için) ─────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Auth ─────────────────────────────────────────────────
# Güçlü rastgele bir string gir (en az 32 karakter)
# Örnek üretmek için: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# ── Admin Credentials ────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# ── Ödeme Sağlayıcısı ────────────────────────────────────
# iyzico (https://dev.iyzipay.com)
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# Stripe (https://dashboard.stripe.com/apikeys)
# STRIPE_SECRET_KEY=sk_test_...
