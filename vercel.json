{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "backend/serverless.cjs": {
      "memory": 512,
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/backend/serverless" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
